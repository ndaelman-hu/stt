# Whisper Model Configuration
# Model size: tiny, base, small, medium, large
MODEL_SIZE=base

# Compute device: auto, cpu, cuda
# auto: automatically detect CUDA availability
DEVICE=auto

# Audio Recording Settings
# Sample rate in Hz (8000-48000)
SAMPLE_RATE=16000

# Maximum recording duration in minutes (1-300)
MAX_DURATION_MINUTES=90

# Stop signal: ctrl_c, enter, space
# ctrl_c: Press Ctrl+C to stop
# enter: Press Enter to stop
# space: Press Space to stop
STOP_SIGNAL=ctrl_c

# Transcription Settings
# Language code (leave empty for auto-detection)
# Examples: en (English), es (Spanish), fr (French), de (German), ja (Japanese), zh (Chinese)
LANGUAGE=

# Task mode: transcribe, translate, both
# transcribe: Keep original language
# translate: Translate to English
# both: Get both transcription and translation
TASK=transcribe

# File Management
# Keep recorded audio files: true, false
KEEP_RECORDINGS=false

# LLM Post-Processing Settings (for meeting minutes)
# Path to llama.cpp binary
LLM_BINARY_PATH=llama.cpp/main

# Path to LLM model file (TinyLlama recommended for speed)
LLM_MODEL_PATH=models/tinyllama-1.1b-chat.gguf

# Enable automatic text cleaning (grammar/punctuation fixes): true, false
LLM_ENABLE_CLEANING=true

# Extract TODOs by default: true, false
# When false, TODOs only extracted via menu option or CLI flag
LLM_EXTRACT_TODOS=false
